<!-- ================================================================
     PAGE: HOME
================================================================ -->
<div id="page-home" class="page-section" style="padding-top:68px;">

  <!-- Hero with Video -->
  <section class="hero">
    <video class="hero-video" autoplay muted loop playsinline>
      <source src="video/7197970-uhd_2160_3840_25fps.mp4" type="video/mp4">
    </video>
    <div class="hero-overlay">
      <h1>🐾 فندق الحيوانات الأليفة</h1>
      <p>نقدم لرفيقك الأليف أرقى تجربة إقامة ورعاية في بيئة آمنة ومريحة مليئة بالحب والاهتمام</p>
      <a href="#" class="btn" data-page="booking">احجز الآن</a>
    </div>
  </section>

  <!-- Why us -->
  <section class="section bg-white">
    <h2 class="section-title">✨ لماذا تختارنا؟</h2>
    <div class="features-grid">
      <div class="feature-card">
        <span class="feature-icon">🏥</span>
        <h3>رعاية صحية متكاملة</h3>
        <p>فريق طبي متخصص على مدار الساعة لضمان صحة وسلامة حيوانك الأليف</p>
      </div>
      <div class="feature-card">
        <span class="feature-icon">🏡</span>
        <h3>أجنحة فاخرة</h3>
        <p>غرف مكيفة ومريحة مصممة خصيصاً لراحة الحيوانات الأليفة</p>
      </div>
      <div class="feature-card">
        <span class="feature-icon">🍖</span>
        <h3>وجبات صحية</h3>
        <p>قوائم طعام متنوعة ومتوازنة تتناسب مع جميع أنواع الحيوانات</p>
      </div>
      <div class="feature-card">
        <span class="feature-icon">🎾</span>
        <h3>مناطق لعب آمنة</h3>
        <p>مساحات واسعة ومجهزة للعب والتمارين الرياضية</p>
      </div>
      <div class="feature-card">
        <span class="feature-icon">📸</span>
        <h3>تحديثات يومية</h3>
        <p>صور وفيديوهات يومية لإبقائك على اطلاع بحال رفيقك</p>
      </div>
      <div class="feature-card">
        <span class="feature-icon">🚗</span>
        <h3>خدمة نقل</h3>
        <p>نوفر خدمة استلام وتوصيل من وإلى منزلك بكل أمان</p>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="section">
    <h2 class="section-title">📸 معرض الصور</h2>
    <div class="gallery-grid">
      <div class="gallery-item">
        <img src="images/istockphoto-885571364-2048x2048.jpg" alt="كلب سعيد في الفندق">
        <div class="gallery-caption">
          <h4>لحظات سعيدة</h4>
          <p>حيواناتنا الأليفة تستمتع بإقامتها</p>
        </div>
      </div>
      <div class="gallery-item">
        <img src="images/istockphoto-1059650734-2048x2048.jpg" alt="رعاية الحيوانات">
        <div class="gallery-caption">
          <h4>رعاية متخصصة</h4>
          <p>فريقنا يعتني بكل تفصيلة</p>
        </div>
      </div>
      <div class="gallery-item">
        <img src="images/istockphoto-1125630990-2048x2048.jpg" alt="حيوانات أليفة تلعب">
        <div class="gallery-caption">
          <h4>وقت اللعب</h4>
          <p>أنشطة ترفيهية متنوعة</p>
        </div>
      </div>
      <div class="gallery-item">
        <img src="images/istockphoto-1216277209-2048x2048.jpg" alt="راحة وأمان">
        <div class="gallery-caption">
          <h4>راحة تامة</h4>
          <p>بيئة مريحة وآمنة</p>
        </div>
      </div>
      <div class="gallery-item">
        <img src="images/istockphoto-1494578573-2048x2048.jpg" alt="أصدقاء جدد">
        <div class="gallery-caption">
          <h4>صداقات جديدة</h4>
          <p>تعرف على أصدقاء جدد</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Packages Preview -->
  <section class="section bg-white">
    <h2 class="section-title">💰 باقاتنا</h2>
    <div class="packages-grid">
      <div class="package-card">
        <div class="package-header">
          <h3>الباقة الأساسية</h3>
          <div class="package-price">75 <span>ريال/يوم</span></div>
        </div>
        <div class="package-body">
          <ul class="package-features">
            <li>✅ إقامة في غرفة مكيفة</li>
            <li>✅ وجبتين يومياً</li>
            <li>✅ وقت لعب يومي</li>
            <li>✅ تحديث صور يومي</li>
          </ul>
          <a href="#" class="btn" data-page="booking">احجز الآن</a>
        </div>
      </div>
      <div class="package-card">
        <div class="package-header" style="background:linear-gradient(135deg,#c9a0a0,#b08a8a);">
          <h3>الباقة المميزة ⭐</h3>
          <div class="package-price">120 <span>ريال/يوم</span></div>
        </div>
        <div class="package-body">
          <ul class="package-features">
            <li>✅ إقامة في جناح فاخر</li>
            <li>✅ ثلاث وجبات يومياً</li>
            <li>✅ جلسات لعب إضافية</li>
            <li>✅ فيديوهات يومية</li>
            <li>✅ تيشيرت مجاني</li>
          </ul>
          <a href="#" class="btn" data-page="booking">احجز الآن</a>
        </div>
      </div>
      <div class="package-card">
        <div class="package-header" style="background:linear-gradient(135deg,#d4b896,#a08060);">
          <h3>الباقة VIP 👑</h3>
          <div class="package-price">200 <span>ريال/يوم</span></div>
        </div>
        <div class="package-body">
          <ul class="package-features">
            <li>✅ جناح ملكي خاص</li>
            <li>✅ قائمة طعام مخصصة</li>
            <li>✅ مدرب خاص</li>
            <li>✅ جلسات سباحة</li>
            <li>✅ رعاية صحية شاملة</li>
            <li>✅ هدية تذكارية</li>
          </ul>
          <a href="#" class="btn" data-page="booking">احجز الآن</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="background:linear-gradient(135deg,var(--rose-light),var(--rose-dark));color:white;text-align:center;">
    <h2 style="font-size:36px;margin-bottom:20px;">🐾 جاهز لحجز إقامة رفيقك؟</h2>
    <p style="font-size:18px;margin-bottom:30px;opacity:0.9;">احجز الآن واستمتع بخصم 15% على أول حجز</p>
    <a href="#" class="btn" style="background:white;color:var(--rose-dark);" data-page="booking">احجز الآن</a>
  </section>


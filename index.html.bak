<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>فندق الحيوانات الأليفة</title>
  <link rel="stylesheet" href="css/style.css">
</head>
<body>

<!-- ===== Navigation ===== -->
<nav>
  <ul class="nav-links">
    <li><a href="#" data-page="home" class="active">الرئيسية</a></li>
    <li><a href="#" data-page="facilities">المرافق</a></li>
    <li><a href="#" data-page="packages">الحزم</a></li>

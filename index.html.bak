<!-- ================================================================
     PAGE: BOOKING
================================================================ -->
<div id="page-booking" class="page-section" style="padding-top:68px;">

  <div class="page-hero">
    <h1>📝 حجز الإقامة</h1>
    <p>احجز إقامة رفيقك الأليف في خطوات بسيطة</p>
  </div>

  <section class="section bg-white">
    <h2 class="section-title">📋 نموذج الحجز</h2>
    <div style="max-width:700px;margin:0 auto;">
      <form class="booking-form">
        <h3 style="margin-bottom:20px;color:var(--rose-dark);font-size:20px;">👤 بيانات المالك</h3>

        <div class="form-group">
          <label>الاسم الكامل *</label>
          <input type="text" class="form-control" placeholder="أدخل اسمك الكامل" required>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
          <div class="form-group">
            <label>رقم الجوال *</label>
            <input type="tel" class="form-control" placeholder="05xxxxxxxx" required>
          </div>
          <div class="form-group">
            <label>البريد الإلكتروني *</label>
            <input type="email" class="form-control" placeholder="example@email.com" required>
          </div>
        </div>

        <div class="form-group">
          <label>المدينة</label>
          <select class="form-control">
            <option value="">اختر المدينة</option>
            <option>الرياض</option>
            <option>جدة</option>
            <option>الدمام</option>
            <option>مكة المكرمة</option>
            <option>المدينة المنورة</option>
            <option>أخرى</option>
          </select>
        </div>

        <h3 style="margin:30px 0 20px;color:var(--rose-dark);font-size:20px;">🐾 بيانات الحيوان الأليف</h3>

        <div class="form-group">
          <label>اسم الحيوان الأليف *</label>
          <input type="text" class="form-control" placeholder="اسم رفيقك الأليف" required>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
          <div class="form-group">
            <label>نوع الحيوان *</label>
            <select class="form-control" required>
              <option value="">اختر النوع</option>
              <option>كلب</option>
              <option>قطة</option>
              <option>طائر</option>
              <option>أرنب</option>
              <option>أخرى</option>
            </select>
          </div>
          <div class="form-group">
            <label>السلالة</label>
            <input type="text" class="form-control" placeholder="مثال: جولدن ريتريفر">
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
          <div class="form-group">
            <label>العمر</label>
            <input type="text" class="form-control" placeholder="مثال: سنتان">
          </div>
          <div class="form-group">
            <label>الوزن (كجم)</label>
            <input type="number" class="form-control" placeholder="مثال: 15">
          </div>
        </div>

        <h3 style="margin:30px 0 20px;color:var(--rose-dark);font-size:20px;">📅 تفاصيل الحجز</h3>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
          <div class="form-group">
            <label>تاريخ الوصول *</label>
            <input type="date" class="form-control" required>
          </div>
          <div class="form-group">
            <label>تاريخ المغادرة *</label>
            <input type="date" class="form-control" required>
          </div>
        </div>

        <div class="form-group">
          <label>اختر الباقة *</label>
          <select class="form-control" required>
            <option value="">اختر الباقة المناسبة</option>
            <option>الباقة الأساسية - 75 ريال/يوم</option>
            <option>الباقة المميزة - 120 ريال/يوم</option>
            <option>الباقة VIP - 200 ريال/يوم</option>
          </select>
        </div>

        <div class="form-group">
          <label>خدمات إضافية</label>
          <div style="display:flex;flex-wrap:wrap;gap:15px;margin-top:10px;">
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;"><input type="checkbox"> جلسة تجميل</label>
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;"><input type="checkbox"> تدريب خاص</label>
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;"><input type="checkbox"> خدمة النقل</label>
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;"><input type="checkbox"> جلسة سباحة</label>
          </div>
        </div>

        <div class="form-group">
          <label>رمز الخصم</label>
          <input type="text" class="form-control" placeholder="أدخل رمز الخصم إن وجد">
        </div>

        <div class="form-group">
          <label>ملاحظات صحية أو سلوكية</label>
          <textarea class="form-control" placeholder="أي معلومات مهمة عن صحة أو سلوك حيوانك الأليف"></textarea>
        </div>

        <div class="form-group">
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
            <input type="checkbox" required> أوافق على الشروط والأحكام *
          </label>
        </div>

        <button type="submit" class="btn" style="width:100%;">📝 تأكيد الحجز</button>
      </form>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">📌 ملاحظات مهمة</h2>
    <div class="features-grid" style="max-width:900px;">
      <div class="feature-card"><span class="feature-icon">💉</span><h3>شهادة التطعيم</h3><p>يجب إحضار شهادة تطعيمات سارية المفعول عند الوصول</p></div>
      <div class="feature-card"><span class="feature-icon">📋</span><h3>التأكيد</h3><p>سيتم إرسال رسالة تأكيد على جوالك وبريدك الإلكتروني</p></div>
      <div class="feature-card"><span class="feature-icon">💰</span><h3>الدفع</h3><p>يمكن الدفع نقداً أو بالبطاقة عند الوصول أو تحويل بنكي</p></div>
      <div class="feature-card"><span class="feature-icon">📞</span><h3>للاستفسارات</h3><p>اتصل بنا على 920000000 لأي استفسار</p></div>
    </div>
  </section>

</div><!-- /page-booking -->

